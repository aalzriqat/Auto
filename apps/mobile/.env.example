# Required Expo public env vars — copy to apps/mobile/.env before building.
# All are EXPO_PUBLIC_* (inlined into the JS bundle at build time) and are
# client-safe/publishable values, not secrets.
EXPO_PUBLIC_CONVEX_URL=https://<your-deployment>.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://<your-deployment>.convex.site
# The Clerk publishable key MUST belong to the same Clerk instance that the
# target Convex deployment trusts (its CLERK_JWT_ISSUER_DOMAIN). Mismatch =
# Clerk signs in but Convex rejects the token (isAuthenticated stays false),
# which looks like a silent "signed out" state. The prod deployment
# (kindly-hound-172) trusts clerk.autoflowdealer.com, so point mobile at the
# pk_live_... key, not the pk_test_... dev instance.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_or_live_...
EXPO_PUBLIC_APP_SCHEME=autoflow
EXPO_PUBLIC_APP_URL=https://autoflowdealer.com/
# Optional — already hardcoded as a default in app.config.ts:
EXPO_PUBLIC_EAS_PROJECT_ID=bddc3f4c-6f00-402c-913f-380afbd7fa05
