# Convex
# These will be populated automatically if you use `npx convex dev`
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk Configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Application URL (for generating invite links etc.)
NEXT_PUBLIC_APP_URL=https://www.autoflowdealer.com/

# Cloudflare Turnstile public key for dealer-site and marketplace lead forms.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Backend only variables (Need to be set in Convex Dashboard)
# CLERK_JWT_ISSUER_DOMAIN=
# RESEND_API_KEY=
# CLERK_WEBHOOK_SECRET=
# TURNSTILE_SECRET_KEY=

# Instagram/Facebook OAuth (Meta App) — optional, only needed for
# Settings > Integrations (social posting). Set via `npx convex env set`.
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=

# Verify token for the /instagram-webhook handshake (comments + DMs).
# Pick any random string, set it here AND as the "Verify Token" when
# configuring the webhook in the Meta dashboard. Set via `npx convex env set`.
# INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# Optional: protects the Convex /load-test/health probe used by k6.
# Set via `npx convex env set LOAD_TEST_SECRET <long-random-secret>`.
# LOAD_TEST_SECRET=

# Optional SMS provider for Receivables & Collections reminders.
# If unset, SMS reminders are logged as skipped while WhatsApp/manual reminders continue.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Sentry Error Monitoring
# Get these from https://sentry.io → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Get these from https://sentry.io → Organization → Settings
SENTRY_ORG=
SENTRY_PROJECT=
# Optional: used for uploading source maps during build
SENTRY_AUTH_TOKEN=
