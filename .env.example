# Convex
# These will be populated automatically if you use `npx convex dev`
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Clerk Configuration
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Application URL (for generating invite links etc.)
NEXT_PUBLIC_APP_URL=https://www.autoflowdealer.com/

# Backend only variables (Need to be set in Convex Dashboard)
# CLERK_JWT_ISSUER_DOMAIN=
# RESEND_API_KEY=
# CLERK_WEBHOOK_SECRET=

# Instagram/Facebook OAuth (Meta App) — optional, only needed for
# Settings > Integrations (social posting). Set via `npx convex env set`.
# INSTAGRAM_APP_ID=
# INSTAGRAM_APP_SECRET=

# Sentry Error Monitoring
# Get these from https://sentry.io → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Get these from https://sentry.io → Organization → Settings
SENTRY_ORG=
SENTRY_PROJECT=
# Optional: used for uploading source maps during build
SENTRY_AUTH_TOKEN=
