{
  "name": "auto",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "convex dev --start \"next dev -H 0.0.0.0\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage --silent=passed-only",
    "test:coverage:sonar": "vitest run convex --coverage --silent=passed-only --coverage.include=convex/collections.ts --coverage.include=convex/applications.ts --coverage.include=convex/memberships.ts --coverage.include=convex/transactions.ts --coverage.include=convex/finance.ts --coverage.include=convex/subledger.ts --coverage.include=convex/accountingReports.ts --coverage.thresholds.lines=0 --coverage.thresholds.functions=0 --coverage.thresholds.branches=0 --coverage.thresholds.statements=0",
    "typecheck": "tsc --noEmit",
    "typecheck:convex": "tsc -p convex/tsconfig.json --noEmit",
    "typecheck:cypress": "tsc -p cypress/tsconfig.json --noEmit",
    "e2e:playwright": "playwright test",
    "e2e:cypress": "cypress run",
    "convex:codegen": "convex codegen --typecheck enable",
    "dealer-worker:typecheck": "tsc -p dealer-worker/tsconfig.json --noEmit",
    "dealer-worker:build": "npm run --prefix dealer-worker build",
    "load:smoke": "k6 run load-tests/k6/autoflow-smoke.js",
    "load:auth-smoke": "k6 run load-tests/k6/autoflow-authenticated-smoke.js",
    "load:1000": "k6 run load-tests/k6/autoflow-1000-users.js"
  },
  "dependencies": {
    "@clerk/localizations": "^4.9.0",
    "@clerk/nextjs": "^7.4.2",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.16",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@sentry/nextjs": "^10.56.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clerk": "^1.5.0",
    "clsx": "^2.1.1",
    "convex": "^1.42.1",
    "date-fns": "^4.4.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.40.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.17.0",
    "next": "^16.2.7",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-day-picker": "^8.10.1",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.77.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.4",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "svix": "^1.95.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "web-push": "^3.6.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.2.2",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/cypress": "^10.1.3",
    "@testing-library/react": "^16.3.2",
    "@testsprite/testsprite-mcp": "0.0.38",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.9",
    "convex-test": "^0.0.53",
    "cypress": "^15.18.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
